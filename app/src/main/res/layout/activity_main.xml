<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_header"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Number Book"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvContactCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 contacts"
                android:textSize="11sp"
                android:textColor="@color/accent_cyan"
                android:background="@drawable/bg_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- Barre de recherche -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etKeyword"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:hint="Rechercher nom ou numéro..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:background="@drawable/bg_search_field"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:text="→"
                android:textSize="18sp"
                android:textColor="@color/bg_deep"
                android:background="@drawable/bg_btn_cyan"
                android:padding="0dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- BOUTONS D'ACTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnLoadContacts"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="Charger"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_btn_outline" />

        <Button
            android:id="@+id/btnSyncContacts"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="Synchroniser →"
            android:textSize="12sp"
            android:textColor="@color/accent_cyan"
            android:background="@drawable/bg_btn_cyan_outline" />
    </LinearLayout>

    <!-- LABEL SECTION -->
    <TextView
        android:id="@+id/tvSectionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CONTACTS"
        android:textSize="10sp"
        android:textColor="@color/text_hint"
        android:letterSpacing="0.2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <!-- LISTE -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false" />

</LinearLayout>